#!/bin/bash
set -e

# Script to build and run the openbmc-subproject-docker container
# Uses podman with host networking and mounts the parent directory of the
# git repository root as /workspace, then sets working dir to the repo
# subdirectory matching the current directory

# Get the directory where this script is located (for Dockerfile)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

IMAGE_NAME="openbmc-subproject-docker"

# Function to display usage
usage() {
    echo "Usage: $0 [build|run|both] [command...]"
    echo ""
    echo "Commands:"
    echo "  build       - Build the Docker image"
    echo "  run         - Run container with specified command"
    echo "  both        - Build and then run (default if no command specified)"
    echo ""
    echo "This script mounts the parent directory of the git repository root"
    echo "into /workspace in the container, and sets the working directory to"
    echo "the corresponding subdirectory based on your current location."
    echo ""
    echo "Examples:"
    echo "  $0 build"
    echo "  $0 run bash"
    echo "  $0 run meson compile"
    echo "  $0 both meson test"
    echo "  $0  # same as 'both' with interactive bash"
    exit 1
}

# Function to build the image
build_image() {
    echo "=== Building Docker image: $IMAGE_NAME ==="
    echo "Dockerfile location: $SCRIPT_DIR"
    podman build --network host -t "$IMAGE_NAME" "$SCRIPT_DIR"
    echo "=== Build complete ==="
}

# Function to run the container
run_container() {
    local cmd="$@"

    # If no command specified, use interactive bash
    if [ -z "$cmd" ]; then
        cmd="bash"
    fi

    # Find the git repository root
    local current_dir="$(pwd)"
    local repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"

    if [ -z "$repo_root" ]; then
        echo "Error: Not in a git repository"
        exit 1
    fi

    # Get the parent directory of the repo root
    local repo_parent="$(dirname "$repo_root")"
    local repo_name="$(basename "$repo_root")"

    # Calculate the relative path from repo root to current directory
    local rel_path="${current_dir#$repo_root}"
    rel_path="${rel_path#/}"  # Remove leading slash if present

    # Construct the workspace path: /workspace/<repo_name>/<rel_path>
    local workspace_dir="/workspace/$repo_name"
    if [ -n "$rel_path" ]; then
        workspace_dir="$workspace_dir/$rel_path"
    fi

    echo "=== Running container with host networking ==="
    echo "Repository root: $repo_root"
    echo "Mount: $repo_parent -> /workspace"
    echo "Working dir: $workspace_dir"
    echo "Command: $cmd"
    echo ""

    podman run --rm -it \
        --network host \
        -v "$repo_parent:/workspace:Z" \
        -w "$workspace_dir" \
        "$IMAGE_NAME" \
        $cmd
}

# Parse arguments
ACTION="${1:-both}"
shift || true

case "$ACTION" in
    build)
        build_image
        ;;
    run)
        run_container "$@"
        ;;
    both)
        build_image
        run_container "$@"
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        # If first arg is not a recognized action, assume it's a command to run
        # and treat as "both" action
        build_image
        run_container "$ACTION" "$@"
        ;;
esac
